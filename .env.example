# ---------------------------------------------------------------------------
# Hydrogen LLM Proxy - environment configuration
# Copy to `.env` and fill in. Never commit your real `.env`.
# ---------------------------------------------------------------------------

# HTTP port the proxy + dashboard listen on.
PORT=8080

# Directory for the SQLite database file (mounted as a volume in Docker).
DATA_DIR=/data

# ---------------------------------------------------------------------------
# SECURITY (optional - leave blank to auto-generate)
# ---------------------------------------------------------------------------
# If either value below is left blank, Hydrogen generates a strong random one on
# first boot and stores it in DATA_DIR/hydrogen-secrets.json (persisted with your
# data, so it stays stable across restarts). For stronger security you may set
# them explicitly here instead.

# Master key used to encrypt provider API keys at rest (AES-256-GCM).
# Must be 32 bytes, base64-encoded. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# CHANGING THIS AFTER FIRST BOOT WILL MAKE STORED PROVIDER KEYS UNREADABLE.
PROXY_MASTER_KEY=

# Secret used to sign dashboard session cookies (any long random string >= 16 chars).
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
SESSION_SECRET=

# ---------------------------------------------------------------------------
# FIRST-RUN ADMIN (created only if no users exist yet)
# ---------------------------------------------------------------------------
# Leave ADMIN_PASSWORD blank to have a temporary password generated and printed
# in the startup logs; you will be asked to set your own password at first login.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=

# ---------------------------------------------------------------------------
# OPTIONAL
# ---------------------------------------------------------------------------

# How long a dashboard session stays valid.
SESSION_TTL=12h

# Max characters of request/response payload stored per log row (0 = unlimited).
LOG_PAYLOAD_MAX_CHARS=2000000

# Session cookie Secure flag: 'auto' sets it only on HTTPS requests (honouring
# X-Forwarded-Proto). Use 'false' behind a plain-HTTP proxy, 'true' to force.
COOKIE_SECURE=auto

# Set to 'production' in Docker; 'development' enables verbose logging.
NODE_ENV=production
